# =============================================================================
# VoidAccess Configuration Environment Variables
# Copy this file to .env and fill in the values you need
# =============================================================================

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://voidaccess:password@localhost:5432/voidaccess

# JWT secret for authentication (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=

# -----------------------------------------------------------------------------
# Optional: LLM Providers
# Add API keys for providers you want to use
# -----------------------------------------------------------------------------

# OpenAI (GPT-4, GPT-4o, etc.)
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Google AI (Gemini)
GOOGLE_API_KEY=

# OpenRouter (aggregator for many models)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Groq (fast inference — free tier, no credit card required)
GROQ_API_KEY=

# Ollama (local models)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# llama.cpp (local quantized models)
LLAMA_CPP_BASE_URL=http://127.0.0.1:8080

# -----------------------------------------------------------------------------
# Optional: Threat Intel Enrichment
# -----------------------------------------------------------------------------

# AlienVault OTX (Open Threat Exchange)
OTX_API_KEY=

# VirusTotal (file hash enrichment — free tier)
VT_API_KEY=

# Abuse.ch (malware URL blocking)
ABUSECH_API_KEY=

# -----------------------------------------------------------------------------
# Optional: Blockchain Enrichment
# -----------------------------------------------------------------------------

# BlockCypher (BTC/ETH wallet lookup)
BLOCKCYPHER_TOKEN=

# Etherscan (ETH wallet lookup)
ETHERSCAN_API_KEY=

# -----------------------------------------------------------------------------
# Optional: Caching & Rate Limiting
# -----------------------------------------------------------------------------

# Redis for caching, rate limiting, and token blacklist
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Tor Configuration
# -----------------------------------------------------------------------------

# Tor SOCKS5 proxy (default works with local Tor installation)
TOR_PROXY_HOST=127.0.0.1
TOR_PROXY_PORT=9050

# -----------------------------------------------------------------------------
# Optional: Internationalization
# -----------------------------------------------------------------------------

# DeepL for translation
DEEPL_API_KEY=

# Comma-separated languages for query expansion
# Default: en,ru,zh
I18N_LANGUAGES=en,ru,zh

# -----------------------------------------------------------------------------
# Optional: Playwright (JS rendering)
# -----------------------------------------------------------------------------

# Enable Playwright for JS-rendered .onion pages
# Set to 'false' to disable (saves memory)
PLAYWRIGHT_ENABLED=true

# -----------------------------------------------------------------------------
# Optional: Debug & Development
# -----------------------------------------------------------------------------

# Disable rate limiting (for development only)
DISABLE_RATE_LIMIT=false
