# =============================================================================
# VoidAccess Configuration Environment Variables
# Copy this file to .env and fill in the values you need
# =============================================================================

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://voidaccess:password@localhost:5432/voidaccess

# JWT secret for authentication (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=

# -----------------------------------------------------------------------------
# Optional: LLM Providers
# Add API keys for providers you want to use
# -----------------------------------------------------------------------------

# Default LLM model (used when no model is selected)
# Format: provider/model-name
# Examples:
#   openrouter/deepseek/deepseek-chat  (recommended)
#   openrouter/meta-llama/llama-3.3-70b-instruct:free
#   groq/llama-3.3-70b-versatile
#   gpt-4o-mini
#   claude-haiku-4-5-20251001
#   gemini-1.5-flash
DEFAULT_MODEL=openrouter/deepseek/deepseek-chat

# OpenAI (GPT-4, GPT-4o, etc.)
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Google AI (Gemini)
GOOGLE_API_KEY=

# OpenRouter (aggregator for many models)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Groq (fast inference — free tier, no credit card required)
GROQ_API_KEY=

# Ollama (local models)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# llama.cpp (local quantized models)
LLAMA_CPP_BASE_URL=http://127.0.0.1:8080

# -----------------------------------------------------------------------------
# Optional: Threat Intel Enrichment
# -----------------------------------------------------------------------------

# AlienVault OTX (Open Threat Exchange)
OTX_API_KEY=

# VirusTotal (file hash enrichment — free tier)
VT_API_KEY=

# Abuse.ch (malware URL blocking)
ABUSECH_API_KEY=

# -----------------------------------------------------------------------------
# Optional: Blockchain Enrichment
# -----------------------------------------------------------------------------

# BlockCypher (BTC/ETH wallet lookup)
BLOCKCYPHER_TOKEN=

# Etherscan (ETH wallet lookup)
ETHERSCAN_API_KEY=

# -----------------------------------------------------------------------------
# Optional: Paste Site Scraping (clearnet — no Tor)
# -----------------------------------------------------------------------------

# Searches public paste sites for intelligence (Pastebin, dpaste, paste.ee,
# Rentry).  No API key required.  Set to "false" to disable entirely.
PASTE_SCRAPING_ENABLED=true

# Max pastes to fetch per investigation across all paste sources.
PASTE_MAX_RESULTS=15

# -----------------------------------------------------------------------------
# Optional: GitHub Scraping (clearnet — no Tor)
# -----------------------------------------------------------------------------

# Searches GitHub for leaked configs, malware, C2 infrastructure, and
# security research.  No token required but rate limited (10 req/min).
# With token: 30 req/min — get one free at
#   https://github.com/settings/tokens
# Scopes needed: none (public repos only).
GITHUB_SCRAPING_ENABLED=true
GITHUB_TOKEN=
GITHUB_MAX_RESULTS=15

# -----------------------------------------------------------------------------
# Optional: GitLab Scraping (clearnet — no Tor)
# -----------------------------------------------------------------------------

# Searches GitLab for malware tooling, exploit code, and threat actor configs
# that often persist on GitLab after being removed from GitHub.  No token
# required but rate limited (~15 req/min).  With token: ~60 req/min.
# Get a personal access token (no scopes needed) at:
#   https://gitlab.com/-/profile/personal_access_tokens
GITLAB_SCRAPING_ENABLED=true
GITLAB_TOKEN=
GITLAB_MAX_RESULTS=15

# -----------------------------------------------------------------------------
# Optional: RSS Threat Intelligence Feeds (clearnet — no Tor, no API key)
# -----------------------------------------------------------------------------

# Fetches recent articles from curated security blogs (Krebs on Security,
# BleepingComputer, Cisco Talos, Mandiant, CrowdStrike, Unit 42, CISA, etc.)
# Feed results are cached for 1 hour.  Significantly improves summary quality
# by grounding the LLM in authoritative, named journalist/researcher sources.
RSS_FEEDS_ENABLED=true
RSS_MAX_ARTICLES=20

# -----------------------------------------------------------------------------
# Optional: DNS/WHOIS Enrichment
# Queries CIRCL passive DNS and RDAP WHOIS for IP and domain entities.
# Free, no auth required. Finds infrastructure overlap and reuse patterns.
# -----------------------------------------------------------------------------

DNS_ENRICHMENT_ENABLED=true

# SecurityTrails API key (optional)
# Provides more detailed DNS history. Free tier: 50 queries/month.
# Sign up: https://securitytrails.com/corp/api
SECURITYTRAILS_API_KEY=

# -----------------------------------------------------------------------------
# Optional: Caching & Rate Limiting
# -----------------------------------------------------------------------------

# Redis for caching, rate limiting, and token blacklist
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Tor Configuration
# -----------------------------------------------------------------------------

# Tor SOCKS5 proxy (default works with local Tor installation)
TOR_PROXY_HOST=127.0.0.1
TOR_PROXY_PORT=9050

# -----------------------------------------------------------------------------
# Optional: Internationalization
# -----------------------------------------------------------------------------

# DeepL for translation
DEEPL_API_KEY=

# Comma-separated languages for query expansion
# Default: en,ru,zh
I18N_LANGUAGES=en,ru,zh

# -----------------------------------------------------------------------------
# Optional: Playwright (JS rendering)
# -----------------------------------------------------------------------------

# Enable Playwright for JS-rendered .onion pages
# Set to 'false' to disable (saves memory)
PLAYWRIGHT_ENABLED=true

# -----------------------------------------------------------------------------
# Optional: IP Reputation Enrichment
# Feodo Tracker and C2IntelFeeds are free and need no API key.
# AbuseIPDB and GreyNoise require free accounts.
# -----------------------------------------------------------------------------

# AbuseIPDB: community IP abuse reports (1000 checks/day on free tier)
# Sign up: https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=

# GreyNoise: suppresses known benign scanner IPs (Shodan, Censys, researchers)
# from investigation results, reducing noise.
# Sign up: https://www.greynoise.io/pricing
GREYNOISE_API_KEY=

# How often to refresh the Feodo Tracker and C2IntelFeeds blocklists (hours)
C2_FEED_CACHE_TTL=24

# -----------------------------------------------------------------------------
# Optional: Domain Reputation Enrichment
# Enriches DOMAIN entities with subdomains, live scan data, and history.
# crt.sh and Wayback Machine require no keys — fully free and open.
# -----------------------------------------------------------------------------

# URLScan.io: live domain scan data and malicious URL detection
# Optional — free public scan results available without a key (rate limited).
# With a key: higher rate limits and access to more recent scans.
# Sign up: https://urlscan.io/user/signup
URLSCAN_API_KEY=

# Whether to submit new scans to URLScan.io when no existing scan is found.
# WARNING: submissions are PUBLIC and may alert domain operators.
# Keep false for OPSEC-sensitive investigations.
URLSCAN_SUBMIT=false

# -----------------------------------------------------------------------------
# Optional: Hash Reputation Enrichment
# Enriches FILE_HASH_* entities with malware profiles (family, verdict, AV
# detections, sandbox network IOCs).
# MalwareBazaar and ThreatFox require no keys — fully free and open.
# -----------------------------------------------------------------------------

# Hybrid Analysis: full behavioral sandbox analysis (free tier available).
# Extracts verdict, malware family, AV detections, and contacted IPs/domains.
# Sign up: https://www.hybrid-analysis.com/signup
HYBRID_ANALYSIS_API_KEY=

# -----------------------------------------------------------------------------
# Optional: Email Reputation Enrichment
# Enriches EMAIL_ADDRESS entities with breach history and reputation scoring.
# Disposable domain blocklist requires no auth — fully free and open.
# -----------------------------------------------------------------------------

# HaveIBeenPwned: breach history lookup. The authoritative source for whether
# an email appeared in known data breaches. Paid API ($3.50/month individual).
# Most valuable for threat actor attribution — breach history can expose
# password reuse patterns and reveal real identity across platforms.
# Sign up: https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# EmailRep: reputation scoring, disposable detection, and platform presence.
# Works without a key at reduced rate limits. Key increases throughput.
# Sign up: https://emailrep.io/key
EMAILREP_API_KEY=

# -----------------------------------------------------------------------------
# Optional: Debug & Development
# -----------------------------------------------------------------------------

# Disable rate limiting (for development only)
DISABLE_RATE_LIMIT=false
