# Database (internal Docker hostname)
DATABASE_URL=postgresql://voidaccess:voidaccess@postgres:5432/voidaccess

# Tor (internal Docker hostname)
TOR_PROXY_HOST=tor
TOR_PROXY_PORT=9050

# Python
PYTHONUNBUFFERED=1
TF_ENABLE_ONEDNN_OPTS=0
TF_CPP_MIN_LOG_LEVEL=3

# Next.js
NEXT_PUBLIC_API_URL=http://fastapi:8000

# Node
NODE_ENV=production
